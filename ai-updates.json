      "providerName": "Microsoft Copilot",
      "providerColor": "#0078D4",
      "date": "2026-03-14",
      "text": "Business impact: Helps teams retrieve past conversations faster, improving productivity and reducing time spent searching for information.",
      "severity": "low",
      "severityLabel": "Miglioramento",
      "source": "https://learn.microsoft.com/en-us/copilot/microsoft-365/release-notes"
