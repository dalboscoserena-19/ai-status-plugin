      "provider": "copilot",
      "providerName": "Microsoft Copilot",
      "providerColor": "#0078D4",
      "date": "2026-03-14",
      "text": "What changed: AI‑powered skill inferencing, previously available only to Microsoft 365 Copilot and Microsoft Viva licensed users, can now be enabled for Microsoft 365 E3 and E5 users. Admins can turn this capability on directly in the Microsoft 365 admin center. When enabled, AI automatically identi",
      "severity": "info",
      "severityLabel": "Info",
      "source": "https://learn.microsoft.com/en-us/copilot/microsoft-365/release-notes"
    },
    {
      "id": "copilot-1773474731193-3",
      "provider": "copilot",
      "providerName": "Microsoft Copilot",
      "providerColor": "#0078D4",
      "date": "2026-03-14",
      "text": "Open the Microsoft 365 admin center and review the People Skills settings.",
      "severity": "info",
      "severityLabel": "Info",
      "source": "https://learn.microsoft.com/en-us/copilot/microsoft-365/release-notes"
    },
    {
      "id": "copilot-1773474731193-4",
      "provider": "copilot",
      "providerName": "Microsoft Copilot",
      "providerColor": "#0078D4",
      "date": "2026-03-14",
      "text": "Turn on AI‑powered skill inferencing for Microsoft 365 E3 or E5 users.",
      "severity": "info",
      "severityLabel": "Info",
      "source": "https://learn.microsoft.com/en-us/copilot/microsoft-365/release-notes"
