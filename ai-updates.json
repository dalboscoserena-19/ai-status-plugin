    {
      "id": "copilot-1773474731194-7",
      "provider": "copilot",
      "providerName": "Microsoft Copilot",
      "providerColor": "#0078D4",
      "date": "2026-03-14",
      "text": "Microsoft Copilot introduces an explainable AI experience that shows how responses from connected data sources are generated by using inline and deep citations.",
